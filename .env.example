# ============================================================
# Environment Variables Example
# Copy this file to .env for local development (and configure
# the same variables in your Render / Railway / AWS dashboard
# for production deployments).
# ============================================================

# Flask secret key - used for session signing and flash messages.
# Generate a strong random value in production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key

# Port the app listens on. Render/Railway set this automatically.
PORT=5000

# Set to "true" to enable Flask debug mode (NEVER enable in production)
FLASK_DEBUG=false

# Database configuration:
# - Leave DATABASE_URL empty to use the local SQLite database
#   (database/loan_database.db).
# - Set DATABASE_URL to a PostgreSQL connection string to use
#   PostgreSQL instead, e.g.:
#   postgresql://username:password@hostname:5432/database_name
DATABASE_URL=

# SSL mode for PostgreSQL connections (Render/Railway typically require "require")
DB_SSLMODE=require

# Optional: override the path to the trained model directory.
# Leave empty to use the default ./model directory.
MODEL_DIR=
